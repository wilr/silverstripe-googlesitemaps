<?xml version="1.0"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" bootstrap="vendor/silverstripe/cms/tests/bootstrap.php" colors="true" xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.3/phpunit.xsd" failOnWarning="false" failOnDeprecation="false">
  <source>
    <include>
      <directory suffix=".php">src/</directory>
    </include>
  </source>
  <testsuite name="Default">
    <directory>tests</directory>
  </testsuite>
</phpunit>
